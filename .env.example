# ── AI Assistant ──────────────────────────────────────────────────────────────
# Paste your API key here to enable AI-powered answers.
OPENAI_API_KEY=

# Google Gemini API key (priority over OpenAI)
GEMINI_API_KEY=

# ── CRM Connector (optional) ─────────────────────────────────────────────────
# Used by data_connector.CRMConnector
CRM_BASE_URL=
CRM_API_KEY=

# ── SQL Connector (optional) ─────────────────────────────────────────────────
# Example: postgresql+psycopg2://user:password@localhost:5432/sales_db
# Example: sqlite:///sales.db
SQL_CONNECTION_STRING=
SQL_QUERY=SELECT * FROM sales

# ── Security Settings ────────────────────────────────────────────────────────
# JWT secret key for session tokens (generate a random string for production)
JWT_SECRET=change-this-in-production

# Encryption key for 2FA secrets (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Account lockout settings
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Password reset settings
RESET_TOKEN_EXPIRY_HOURS=1

# ── Email Configuration (for password reset) ─────────────────────────────────
# SMTP server settings (example: Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@retailbrain.ai

# Base URL for password reset links (change for production)
APP_BASE_URL=http://localhost:8501
