# ── AI Assistant ──────────────────────────────────────────────────────────────
# Paste your OpenAI API key here to enable GPT-powered answers.
# Leave blank to use the built-in rule-based assistant (no API calls needed).
OPENAI_API_KEY=

# ── CRM Connector (optional) ─────────────────────────────────────────────────
# Used by data_connector.CRMConnector
CRM_BASE_URL=
CRM_API_KEY=

# ── SQL Connector (optional) ─────────────────────────────────────────────────
# Example: postgresql+psycopg2://user:password@localhost:5432/sales_db
# Example: sqlite:///sales.db
SQL_CONNECTION_STRING=
SQL_QUERY=SELECT * FROM sales
